PORT=3000

# Fill the same token into WeChat Official Account message push settings.
WECHAT_TOKEN=my_ai_assistant_2026

# Required for downloading WeChat image messages by MediaId.
WECHAT_APP_ID=replace_with_your_wechat_app_id
WECHAT_APP_SECRET=replace_with_your_wechat_app_secret

# Text model. DeepSeek example.
AI_BASE_URL=https://api.deepseek.com/v1
AI_API_KEY=replace_with_your_deepseek_api_key
AI_MODEL=deepseek-chat
AI_TIMEOUT_MS=4500

# Optional vision model. Use an OpenAI-compatible model that supports image_url input.
# DeepSeek chat is text-only in this project, so use another vision-capable provider here.
VISION_BASE_URL=https://api.openai.com/v1
VISION_API_KEY=replace_with_your_vision_api_key
VISION_MODEL=gpt-4o-mini
VISION_TIMEOUT_MS=8000

# How many recent user/assistant turns to keep per WeChat user while the service is running.
MEMORY_TURNS=6

SYSTEM_PROMPT=你是公众号的AI助理，语气自然、聪明、清晰，像一个可靠的真人助理。你要优先给出有用、可执行的回答，不要空泛客套。问题不明确时，先用一句话追问关键缺口。
